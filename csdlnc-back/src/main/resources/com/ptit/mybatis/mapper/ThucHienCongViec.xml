<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ptit.csdlnc.dao.ThucHienCongViecDAO">

    <!-- ================= RESULT MAP ================= -->
    <resultMap id="ThucHienCongViecResultMap"
               type="com.ptit.csdlnc.model.ThucHienCongViec">
        <id column="ma_nhan_vien" property="maNv"/>
        <id column="ma_cong_viec" property="maCv"/>
    </resultMap>

    <!-- Lấy danh sách nhân viên thực hiện 1 công việc -->
    <select id="getLstThucHienCongViec"
            parameterType="long"
            resultMap="ThucHienCongViecResultMap">
        SELECT *
        FROM thuc_hien_cong_viec
        WHERE ma_cong_viec = #{maCv}
    </select>

    <!-- Lấy theo khóa chính -->
    <select id="getById"
            parameterType="map"
            resultMap="ThucHienCongViecResultMap">
        SELECT *
        FROM thuc_hien_cong_viec
        WHERE ma_nhan_vien = #{maNv}
          AND ma_cong_viec = #{maCv}
    </select>

    <insert id="insert"
            parameterType="com.ptit.csdlnc.model.ThucHienCongViec">
        INSERT INTO thuc_hien_cong_viec (
            ma_nhan_vien,
            ma_cong_viec
        )
        VALUES (
            #{maNv},
            #{maCv}
        )
    </insert>

    <delete id="delete" parameterType="map">
        DELETE
        FROM thuc_hien_cong_viec
        WHERE ma_nhan_vien = #{maNv}
          AND ma_cong_viec = #{maCv}
    </delete>

</mapper>
