<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ptit.csdlnc.dao.PhongBanDAO">

    <resultMap id="PhongBanResultMap" type="com.ptit.csdlnc.model.PhongBan">
        <id column="ma_phong_ban" property="maPhongBan"/>
        <result column="ten_phong_ban" property="tenPhongBan"/>
        <result column="loai_phong" property="loaiPhong"/>
        <result column="ngay_thanh_lap" property="ngayThanhLap"/>
    </resultMap>

    <select id="getAll" resultMap="PhongBanResultMap">
        SELECT * FROM phong_ban
    </select>

    <select id="getById" parameterType="string" resultMap="PhongBanResultMap">
        SELECT * FROM phong_ban WHERE ma_phong_ban= #{maPhongBan}
    </select>

    <insert id="insert" parameterType="com.ptit.csdlnc.model.PhongBan">
        INSERT INTO phong_ban (ten_phong_ban, loai_phong, ngay_thanh_lap)
        VALUES (#{tenPhongBan}, #{loaiPhong}, #{ngayThanhLap})
    </insert>

    <update id="update" parameterType="com.ptit.csdlnc.model.PhongBan">
        UPDATE phong_ban SET
        ten_phong_ban = #{tenPhongBan},
        loai_phong = #{loaiPhong},
        ngay_thanh_lap = #{ngayThanhLap}
        WHERE ma_phong_ban = #{maPhongBan}
    </update>

    <delete id="delete" parameterType="string">
        DELETE FROM phong_ban WHERE ma_phong_ban = #{maPhongBan}
    </delete>

</mapper>