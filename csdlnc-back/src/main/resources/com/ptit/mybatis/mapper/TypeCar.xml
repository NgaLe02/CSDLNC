<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ptit.csdlnc.dao.TypeCarDAO">
	<resultMap type="com.ptit.csdlnc.model.response.TypeCarResponse"
		id="typeCarMap">
		<id property="maLoaiXe" column="maLoaiXe" />
		<result property="tenLoaiXe" column="tenLoaiXe" />
		<result property="soGhe" column="soGhe" />
	</resultMap>

	<select id="getLstTypeCar" resultMap="typeCarMap">
	    SELECT maLoaiXe, tenLoaiXe, soGhe
	    FROM loaixe
	</select>

	
	<insert id="insertTypeCar" parameterType="com.ptit.csdlnc.model.TypeCar">
	    INSERT INTO loaixe (tenLoaiXe, soGhe)
	    VALUES (#{tenLoaiXe}, #{soGhe})
	</insert>
	
	<update id="updateTypeCar" parameterType="com.ptit.csdlnc.model.TypeCar">
	    UPDATE loaixe
	    SET tenLoaiXe = #{tenLoaiXe},
	        soGhe = #{soGhe}
	    WHERE maLoaiXe = #{maLoaiXe}
	</update>

	
	<delete id="deleteTypeCar" parameterType="int">
	    DELETE FROM loaixe
	    WHERE maLoaiXe = #{maLoaiXe}
	</delete>

	
</mapper>