<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ptit.csdlnc.dao.TicketPriceDAO">
    
    <resultMap id="ticketPriceMap" type="com.ptit.csdlnc.model.response.TicketPriceResponse">
        <id property="maGiaVe" column="maGiaVe"/>
        <result property="giaVe" column="giaVe"/>
        <result property="maTuyen" column="maTuyen"/>
        <result property="maMua" column="maMua"/>
         <association property="mua" javaType="com.ptit.csdlnc.model.response.SeasonResponse">
	        <id property="maMua" column="maMua"/>
	        <result property="tenMua" column="tenMua"/>
	    </association>
	     <association property="tuyenDuong" javaType="com.ptit.csdlnc.model.response.RouteResponse">
	        <id property="maTuyen" column="maTuyen"/>
	        <result property="diemDen" column="diemDen"/>
	        <result property="diemKhoiHanh" column="diemKhoiHanh"/>
	    </association>
    </resultMap>

    <select id="getLstTicketPrice" resultMap="ticketPriceMap">
        SELECT G.maGiaVe, 
        G.giaVe, 
        G.maTuyen, 
        G.maMua,
        M.tenMua,
        TD.diemDen,
        TD.diemKhoiHanh
        FROM GiaVe G
        LEFT JOIN mua M on G.maMua = M.maMua
        LEFT JOIN tuyenduong TD on TD.maTuyen = G.maTuyen
    </select>

    <select id="getTicketPriceById" parameterType="int" resultMap="ticketPriceMap">
        SELECT maGiaVe, giaVe, maTuyen, maMua
        FROM GiaVe
        WHERE maGiaVe = #{maGiaVe}
    </select>

    <insert id="insertTicketPrice" parameterType="com.ptit.csdlnc.model.TicketPrice"
            useGeneratedKeys="true" keyProperty="maGiaVe">
        INSERT INTO GiaVe (giaVe, maTuyen, maMua)
        VALUES (#{giaVe}, #{maTuyen}, #{maMua})
    </insert>

    <update id="updateTicketPrice" parameterType="com.ptit.csdlnc.model.TicketPrice">
        UPDATE GiaVe
        SET giaVe = #{giaVe},
            ngayHieuLuc = #{ngayHieuLuc},
            ngayKetThuc = #{ngayKetThuc},
            maTuyen = #{maTuyen},
            maMua = #{maMua}
        WHERE maGiaVe = #{maGiaVe}
    </update>

    <delete id="deleteTicketPrice" parameterType="int">
        DELETE FROM GiaVe
        WHERE maGiaVe = #{maGiaVe}
    </delete>

</mapper>