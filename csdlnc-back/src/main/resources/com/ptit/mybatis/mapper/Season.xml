<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ptit.csdlnc.dao.SeasonDAO">
	<resultMap id="seasonMap" type="com.ptit.csdlnc.model.response.SeasonResponse">
        <id property="maMua" column="maMua"/>
        <result property="tenMua" column="tenMua"/>
    </resultMap>

	<select id="getLstSeason" resultMap="seasonMap">
        SELECT maMua, tenMua
        FROM mua
    </select>

    <select id="getSeasonById" parameterType="int" resultMap="seasonMap">
        SELECT maMua, tenMua
        FROM mua
        WHERE maMua = #{maMua}
    </select>

    <insert id="insertSeason" parameterType="com.ptit.csdlnc.model.Season" useGeneratedKeys="true" keyProperty="maMua">
        INSERT INTO mua (tenMua)
        VALUES (#{tenMua})
    </insert>

    <update id="updateSeason" parameterType="com.ptit.csdlnc.model.Season">
        UPDATE mua
        SET tenMua = #{tenMua}
        WHERE maMua = #{maMua}
    </update>

    <delete id="deleteSeason" parameterType="string">
        DELETE mua
        WHERE maMua = #{maMua}
    </delete>
	
</mapper>