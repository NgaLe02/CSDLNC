    <select id="getAll" resultMap="ThucHienCongDoanResultMap">
        SELECT * FROM thuchiencongdoan
    </select>

    <select id="getById" parameterType="map" resultMap="ThucHienCongDoanResultMap">
        SELECT * FROM thuchiencongdoan WHERE ma_nv = #{maNv} AND ma_cong_doan = #{maCd}
    </select>

    <insert id="insert" parameterType="com.ptit.csdlnc.model.ThucHienCongDoan">
        INSERT INTO thuchiencongdoan (ma_nv, ma_cong_doan)
        VALUES (#{maNv}, #{maCd})
    </insert>

    <update id="update" parameterType="com.ptit.csdlnc.model.ThucHienCongDoan">
        UPDATE thuchiencongdoan SET
        ma_nv = #{maNv},
        ma_cong_doan = #{maCd}
        WHERE ma_nv = #{maNv} AND ma_cong_doan = #{maCd}
    </update>

    <delete id="delete" parameterType="map">
        DELETE FROM thuchiencongdoan WHERE ma_nv = #{maNv} AND ma_cong_doan = #{maCd}
    </delete>

</mapper>