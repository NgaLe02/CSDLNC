<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ptit.csdlnc.dao.CarDAO">
	<resultMap id="carMap" type="com.ptit.csdlnc.model.response.CarResponse">
	    <id property="maXe" column="maXe"/>
	    <result property="bienSo" column="bienSo"/>
	    <result property="tinhTrang" column="tinhTrang"/>
	    <result property="maLoaiXe" column="maLoaiXe"/>
	    
	    <association property="loaiXe" javaType="com.ptit.csdlnc.model.response.TypeCarResponse">
	        <id property="maLoaiXe" column="maLoaiXe"/>
	        <result property="tenLoaiXe" column="tenLoaiXe"/>
	        <result property="soGhe" column="soGhe"/>
	        
	    </association>
	</resultMap>

	<select id="getLstCar" resultMap="carMap">
	    SELECT 
	        c.maXe, 
	        c.bienSo, 
	        c.tinhTrang, 
	        c.maLoaiXe, 
	        t.maLoaiXe AS maLoaiXe, 
	        t.tenLoaiXe AS tenLoaiXe,
	        t.soGhe as soGhe
	    FROM xe c
	    LEFT JOIN loaixe t ON c.maLoaiXe = t.maLoaiXe
	</select>
	
	<select id="checkBienSoExist"
		resultType="boolean">
		 SELECT CASE WHEN COUNT(*) > 0 THEN TRUE ELSE FALSE END
	    FROM xe
	    WHERE bienSo = #{bienSo}
	</select>
	
	
	 <insert id="insertCar" parameterType="com.ptit.csdlnc.model.Car">
        INSERT INTO Xe (maXe, bienSo, tinhTrang, maLoaiXe)
        VALUES (#{maXe}, #{bienSo}, #{tinhTrang}, #{maLoaiXe})
    </insert>
	
    <update id="updateCar" parameterType="com.ptit.csdlnc.model.Car">
        UPDATE Xe
        SET bienSo = #{bienSo},
            tinhTrang = #{tinhTrang},
            maLoaiXe = #{maLoaiXe}
        WHERE maXe = #{maXe}
    </update>

	
    <delete id="deleteCar" parameterType="string">
        DELETE FROM Xe
        WHERE maXe = #{maXe}
    </delete>
	
</mapper>